# Copy this file to `.env` and fill in real values:  cp .env.example .env
#
# `.env` is git-ignored — never commit real secrets. Values already exported in
# your shell or provided by a gateway secret store take precedence over anything
# set here. Leave optional vars blank to keep the script defaults.

# --- Obsidian vault -----------------------------------------------------------
# Absolute path to your Obsidian vault. Referenced by AGENTS.md / README.md
# (Daily Notes and Surface Later folders resolve against it).
OBSIDIAN_VAULT=/home/you/obsidian-vault

# --- x-bookmarks skill --------------------------------------------------------
# OAuth 2.0 client ID for your X app (required).
X_CLIENT_ID=
# Client secret — only for confidential ("Web App") clients; blank for native apps.
X_CLIENT_SECRET=
# Numeric X user id. Optional; auto-resolved via /users/me when blank.
X_USER_ID=
# Refresh-token file path. Optional; defaults to ~/.config/openclaw/x-bookmarks/token.json
X_TOKEN_FILE=
# State-file path. Optional; defaults to ~/.config/openclaw/x-bookmarks/state.json
X_BOOKMARKS_STATE=
# Refresh token. Optional fallback; normally lives in X_TOKEN_FILE, not here.
X_REFRESH_TOKEN=
